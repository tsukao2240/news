# n8n Basic認証
N8N_USER=admin
N8N_PASSWORD=change_this_password

# n8nのホスト名（ローカルの場合はlocalhostでOK）
N8N_HOST=localhost

# Anthropic API Key（Claude API）
# https://console.anthropic.com/settings/keys で取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Discord Webhook URL
# Discordのチャンネル設定 > 連携サービス > ウェブフック から作成
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here
DISCORD_WEBHOOK_URL_AI=https://discord.com/api/webhooks/your_ai_webhook_url_here
